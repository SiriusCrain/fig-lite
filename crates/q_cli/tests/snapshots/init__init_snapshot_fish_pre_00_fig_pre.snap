---
source: crates/q_cli/tests/init.rs
expression: init
---
set -g BAY_SHELL "/bin/zsh"
set -g SHOULD_BAYTERM_LAUNCH "0"
command mkdir -p ~/.local/bin >/dev/null

builtin contains $HOME/.local/bin $PATH
or set --append PATH $HOME/.local/bin

if not test -z "$BAY_NEW_SESSION"
    set --erase BAYTERM_SESSION_ID
    set --erase BAY_TERM
    set --erase BAY_NEW_SESSION
end

# Load parent from env variables
if test -n "$BAY_PARENT"; and test -z "$BAY_SET_PARENT"
    set --export BAY_PARENT $BAY_SET_PARENT
end

if test -z "$SHOULD_BAYTERM_LAUNCH"
    # 0 = Yes, 1 = No, 2 = Fallback to BAY_TERM
    bay _ should-figterm-launch 1>/dev/null 2>&1
    set SHOULD_BAYTERM_LAUNCH $status
end

if test -t 1
    and test -z "$PROCESS_LAUNCHED_BY_BAY"
    and command -v bayterm 1>/dev/null 2>/dev/null
    and test "$SHOULD_BAYTERM_LAUNCH" -eq 0 -o \( "$SHOULD_BAYTERM_LAUNCH" -eq 2 -a \( -z "$BAY_TERM" -o \( -z "$BAY_TERM_TMUX" -a -n "$TMUX" \) \) \)

    if test -z "$BAY_SHELL"
        set BAY_SHELL (bay _ get-shell)
    end
    set BAY_IS_LOGIN_SHELL 0
    if status --is-login
        set BAY_IS_LOGIN_SHELL 1
    end

    # Do not launch bayterm in non-interactive shells (like VSCode Tasks)
    if status --is-interactive
        set BAY_TERM_NAME (command basename "$BAY_SHELL")" (bayterm)"
        if not set -q BAY_TERM_PATH
            if test -x "$HOME/.local/bin/$BAY_TERM_NAME"
                set BAY_TERM_PATH "$HOME/.local/bin/$BAY_TERM_NAME"
            else
                set BAY_TERM_PATH (command -v bayterm || echo "$HOME/.local/bin/bayterm")
            end
        end

        # Need to exec bash because we're using 'exec -a <name>'
        # to set argv[0] and fish's exec doesn't have this option
        exec bash -c "BAY_PARENT=$BAY_PARENT BAY_SHELL=$BAY_SHELL BAY_IS_LOGIN_SHELL=$BAY_IS_LOGIN_SHELL exec -a \"$BAY_TERM_NAME\" \"$BAY_TERM_PATH\""
    end
end
